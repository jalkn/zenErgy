---
---
<div id="page-bg-overlay" class="fixed inset-0 z-[-1]">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_45%,_rgba(15,23,42,0.45)_0%,_rgba(5,5,8,0.95)_75%,_#050508_100%)]"></div>
  <canvas id="quantum-mesh-canvas" class="absolute inset-0 w-full h-full block opacity-25"></canvas>
</div>

<script>
  const initQuantumMesh = () => {
    const canvas = document.getElementById('quantum-mesh-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let points: Array<{ x: number; y: number; ox: number; oy: number; vx: number; vy: number }> = [];
    const spacing = 36;
    const mouse = { x: 0, y: 0, radius: 110, active: false };

    const resizeCanvas = () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      points = [];
      for (let x = 0; x < canvas.width; x += spacing) {
        for (let y = 0; y < canvas.height; y += spacing) {
          points.push({ x, y, ox: x, oy: y, vx: 0, vy: 0 });
        }
      }
    };

    const animate = () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = "rgba(255, 255, 255, 0.15)";
      
      for (let i = 0; i < points.length; i++) {
        const p = points[i];
        if (mouse.active) {
          const dx = mouse.x - p.x;
          const dy = mouse.y - p.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < mouse.radius) {
            const force = (mouse.radius - dist) / mouse.radius;
            const angle = Math.atan2(dy, dx);
            const tx = p.ox - Math.cos(angle) * force * 20;
            const ty = p.oy - Math.sin(angle) * force * 20;
            p.vx += (tx - p.x) * 0.08;
            p.vy += (ty - p.y) * 0.08;
          } else {
            p.vx += (p.ox - p.x) * 0.05;
            p.vy += (p.oy - p.y) * 0.05;
          }
        } else {
          p.vx += (p.ox - p.x) * 0.05;
          p.vy += (p.oy - p.y) * 0.05;
        }

        p.vx *= 0.8;
        p.vy *= 0.8;
        p.x += p.vx;
        p.y += p.vy;

        ctx.beginPath();
        ctx.arc(p.x, p.y, 0.9, 0, Math.PI * 2);
        ctx.fill();
      }
      requestAnimationFrame(animate);
    };

    window.addEventListener('resize', resizeCanvas);
    window.addEventListener('mousemove', (e) => {
      mouse.x = e.clientX;
      mouse.y = e.clientY;
      mouse.active = true;
    });
    window.addEventListener('mouseleave', () => { mouse.active = false; });

    resizeCanvas();
    animate();
  };

  initQuantumMesh();
  document.addEventListener('astro:page-load', initQuantumMesh);
</script>